<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>BoomRx Industry Watch — {{ date_str }}</title>
<style>
  :root{
    --navy:#0f2747; --navy-2:#16335c; --orange:#ff7a18; --orange-soft:#fff1e6;
    --ink:#1b2530; --muted:#6b7785; --line:#e7ebf0; --bg:#f5f7fa; --card:#ffffff;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);
       font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
       line-height:1.5}
  .wrap{max-width:860px;margin:0 auto;padding:0 20px 64px}
  header{background:linear-gradient(135deg,var(--navy),var(--navy-2));color:#fff;
         padding:30px 0 26px;margin-bottom:28px}
  header .wrap{padding-bottom:0}
  .kicker{letter-spacing:.14em;text-transform:uppercase;font-size:12px;
          color:var(--orange);font-weight:700;margin:0 0 6px}
  h1{margin:0;font-size:26px;font-weight:700}
  .meta{color:#aab8cc;font-size:13px;margin-top:8px}
  .count{display:inline-block;background:var(--orange);color:#fff;font-weight:700;
         border-radius:999px;padding:2px 11px;font-size:13px;margin-left:6px}
  h2{font-size:15px;text-transform:uppercase;letter-spacing:.06em;color:var(--navy);
     border-left:4px solid var(--orange);padding-left:10px;margin:34px 0 14px}
  .item{background:var(--card);border:1px solid var(--line);border-radius:10px;
        padding:15px 17px;margin-bottom:11px;transition:border-color .15s}
  .item:hover{border-color:var(--orange)}
  .item a.title{color:var(--navy);font-weight:600;text-decoration:none;font-size:16px}
  .item a.title:hover{text-decoration:underline}
  .summary{color:#33414f;margin:6px 0 0;font-size:14.5px}
  .row{display:flex;align-items:center;gap:10px;margin-top:9px;
       font-size:12px;color:var(--muted)}
  .src{font-weight:600;color:var(--navy-2)}
  .pips{margin-left:auto;color:var(--orange);letter-spacing:1px}
  .wtag{display:inline-block;background:var(--orange);color:#fff;font-size:10px;
        font-weight:700;border-radius:4px;padding:1px 6px;margin-left:6px;
        text-transform:uppercase;letter-spacing:.03em}
  .empty{background:var(--card);border:1px dashed var(--line);border-radius:10px;
         padding:28px;text-align:center;color:var(--muted)}
  footer{margin-top:40px;padding-top:18px;border-top:1px solid var(--line);
         color:var(--muted);font-size:12.5px}
  footer a{color:var(--navy-2)}
  .arch{margin-top:8px;display:flex;flex-wrap:wrap;gap:8px}
  .arch a{font-size:12px;background:#fff;border:1px solid var(--line);
          border-radius:6px;padding:3px 8px;text-decoration:none;color:var(--navy-2)}
  .watchbox{background:#fff8f1;border:1px solid #ffd9b3;border-left:4px solid var(--orange);
            border-radius:10px;padding:14px 16px;margin-bottom:8px}
  .watchbox h3{margin:0 0 9px;font-size:13px;text-transform:uppercase;letter-spacing:.05em;
               color:#b85c00;display:flex;align-items:center;gap:7px}
  .watchitem{padding:7px 0;border-top:1px dashed #ffe0c2}
  .watchitem:first-of-type{border-top:none}
  .watchitem .wl{font-weight:700;color:var(--navy);font-size:13.5px}
  .watchitem .wn{color:#5a4636;font-size:12.5px;margin-top:2px}
</style>
</head>
<body>
<header>
  <div class="wrap">
    <p class="kicker">BoomRx Industry Watch</p>
    <h1>Daily News Digest</h1>
    <div class="meta">{{ date_str }} &nbsp;·&nbsp; generated {{ generated_at }}
      {% if total %}<span class="count">{{ total }} stories</span>{% endif %}</div>
  </div>
</header>

<div class="wrap">

  {% if watch %}
  <div class="watchbox">
    <h3>&#9888; Standing Watch List</h3>
    {% for w in watch %}
    <div class="watchitem">
      <div class="wl">{{ w.label }}</div>
      {% if w.note %}<div class="wn">{{ w.note }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if groups %}
    {% for g in groups %}
    <h2>{{ g.category }}</h2>
      {% for it in g["items"] %}
      <div class="item">
        <a class="title" href="{{ it.link }}">{{ it.title }}</a>
        {% if it.watch_labels %}<span class="wtag">Watch</span>{% endif %}
        {% if it.summary %}<p class="summary">{{ it.summary }}</p>{% endif %}
        <div class="row">
          <span class="src">{{ it.source }}</span>
          <span class="pips">{{ "●" * (it.score or 0) }}</span>
        </div>
      </div>
      {% endfor %}
    {% endfor %}
  {% else %}
    <div class="empty">No new stories cleared the relevance filter today. Check back tomorrow.</div>
  {% endif %}

  <footer>
    Auto-generated from Google News, the Federal Register, and configured RSS feeds,
    summarized by Claude. Relevance scored 1–5; only 3+ shown.
    {% if not is_archive and archives %}
      <div class="arch">
        <span style="color:var(--muted)">Archive:</span>
        {% for a in archives %}<a href="{{ a.href }}">{{ a.date }}</a>{% endfor %}
      </div>
    {% endif %}
  </footer>
</div>
</body>
</html>
